@PACKAGE_INIT@

# helfemConfig.cmake -- config file for consumers doing
#
#   find_package(helfem CONFIG REQUIRED)
#   target_link_libraries(mytarget PRIVATE helfem::helfem)
#
# This exposes the IMPORTED target `helfem::helfem` and chains
# helfem::helfem-common, helfem::legendre, helfem::lib1dfem, helfem::arma
# (Armadillo + BLAS/LAPACK + integer-width defs) and their transitive
# dependencies. Consumer code needs no manual -I<armadillo> or -DARMA_*
# flags -- they are propagated through the exported targets' INTERFACE_*
# properties.

include(CMakeFindDependencyMacro)

# Header-only / config-package dependencies. The range form `3.4...99`
# accepts any Eigen >= 3.4 (a bare `3.4` is read as [3.4, 3.5)).
find_dependency(Eigen3 3.4...99 CONFIG)
find_dependency(wignernj 0.8.0)
# OpenOrbitalOptimizer's header-only imported target is carried in
# helfem-common's INTERFACE_LINK_LIBRARIES.
find_dependency(OpenOrbitalOptimizer)

# OpenMP is carried in helfem-common's INTERFACE_LINK_LIBRARIES, so the
# consumer must be able to recreate OpenMP::OpenMP_CXX.
if(@USE_OPENMP@)
    find_dependency(OpenMP COMPONENTS CXX)
endif()

# Armadillo headers are a PUBLIC dependency (some public headers include
# <armadillo>); BLAS/LAPACK back the eigensolves. Match the integer
# width HelFEM was built with before locating BLAS.
find_dependency(Armadillo 9)
if(NOT @HELFEM_BLAS_PROVIDED_EXTERNALLY@)
    if(@HELFEM_ILP64@)
        set(BLA_SIZEOF_INTEGER 8)
    endif()
    find_dependency(BLAS)
    find_dependency(LAPACK)
endif()

# HDF5 (C++) and libxc back the DFT / checkpoint paths under src/. Only
# looked up when HelFEM was built with its binaries (HELFEM_BINARIES).
if(@HELFEM_HAS_HDF5@)
    find_dependency(HDF5 COMPONENTS CXX)
    find_dependency(PkgConfig)
    pkg_check_modules(LIBXC REQUIRED IMPORTED_TARGET libxc)
endif()

# Bring in the imported targets: helfem::helfem, helfem::helfem-common,
# helfem::legendre, helfem::lib1dfem, helfem::arma (+ helfem::hdf5).
include("${CMAKE_CURRENT_LIST_DIR}/helfemTargets.cmake")

# In-tree, the atomic FE code (TwoDBasis, DFTGrid, gaunt, ... everything
# under src/) lives in libhelfem-common.a, which links PUBLIC to
# libhelfem.a. A downstream target_link_libraries(x helfem::helfem) does
# NOT drag helfem-common in via that PUBLIC link, because helfem-common
# depends on helfem, not the other way round. Consumers reaching for
# helfem::helfem expect the atomic backend to work out of the box, so
# append the higher-level libs to helfem::helfem's interface closure.
if(TARGET helfem::helfem AND TARGET helfem::helfem-common)
    set_property(TARGET helfem::helfem APPEND PROPERTY
        INTERFACE_LINK_LIBRARIES
            helfem::helfem-common helfem::legendre)
endif()

check_required_components(helfem)
